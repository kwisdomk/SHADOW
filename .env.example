# ── Shadow API Configuration ──────────────────────────────────────
# Set to 'true' to use local deterministic mock responses (no network calls)
SHADOW_MOCK_MODE=true

# AMD Developer Cloud / vLLM Endpoint URL
SHADOW_API_BASE=https://api.openai.com/v1

# Qwen Model (e.g. qwen-2.5-7b)
SHADOW_MODEL=qwen-2.5-7b

# Your AMD / OpenAI API Key
SHADOW_API_KEY=your-api-key-here

# Timeout in seconds
SHADOW_TIMEOUT=30.0
